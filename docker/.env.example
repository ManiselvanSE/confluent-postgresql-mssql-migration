# Copy to .env and fill with your values. Never commit .env.

# Confluent Cloud (destination)
CCLOUD_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
CCLOUD_API_KEY=<CONFLUENT_CLOUD_API_KEY>
CCLOUD_API_SECRET=<CONFLUENT_CLOUD_API_SECRET>
SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-east-1.aws.confluent.cloud
SR_API_KEY=<SCHEMA_REGISTRY_API_KEY>
SR_API_SECRET=<SCHEMA_REGISTRY_API_SECRET>

# AWS (for MSK IAM auth - Replicator consumes from MSK)
AWS_REGION=us-east-1
# AWS credentials: use ~/.aws/credentials or IAM role on Azure VM
